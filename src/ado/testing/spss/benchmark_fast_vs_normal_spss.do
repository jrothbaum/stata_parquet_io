set more off
set varabbrev off

// Benchmark: pq use_spss  fast (cached) vs  normal (streaming)
// Data generated by pq save_spss so no external file dependency.

capture program drop build_bench_data
program define build_bench_data
	version 16
	syntax, n_rows(integer)

	clear
	set obs `n_rows'

	gen long   id   = _n
	gen byte   grp  = mod(_n, 20)
	gen double x1   = rnormal()
	gen double x2   = runiform() * 1000
	gen double x3   = (rnormal() * 10) + grp
	gen double x4   = sqrt(_n)
	gen int    i1   = floor(runiform() * 32740)
	gen int    i2   = floor(runiform() * 5000) - 2500
	gen str8   s1   = char(65 + mod(_n, 26)) + string(mod(_n, 100))
	gen str20  s2   = "row_" + string(_n) + "_g" + string(grp)
end

local sizes "10000 100000 500000 1000000"
local reps  = 5

tempfile spss_tmp
local spss_file "`spss_tmp'.sav"

di as text "Benchmark: pq use_spss  fast (cached) vs  normal (streaming)  [spss]"
di as text "Reps per cell: `reps'"
di as text ""
di as text "n_rows    | normal(s) | fast(s)  | speedup"
di as text "----------|-----------|----------|--------"

set seed 20260304

foreach n of local sizes {
	build_bench_data, n_rows(`n')
	pq save_spss "`spss_file'", replace

	timer clear

	forvalues r = 1/`reps' {
		clear
		timer on 1
		pq use_spss using "`spss_file'", clear
		timer off 1
		assert _N == `n'
	}

	forvalues r = 1/`reps' {
		clear
		timer on 2
		pq use_spss using "`spss_file'", clear fast
		timer off 2
		assert _N == `n'
	}

	timer list 1
	local t_normal = r(t1) / `reps'
	timer list 2
	local t_fast   = r(t2) / `reps'
	local speedup  = `t_normal' / max(`t_fast', 1e-9)

	di as result ///
		%9.0gc `n' " | " ///
		%9.4f `t_normal' " | " ///
		%8.4f `t_fast' " | " ///
		%5.2f `speedup' "x"
}

capture erase "`spss_file'"

di as result _newline "Done."
