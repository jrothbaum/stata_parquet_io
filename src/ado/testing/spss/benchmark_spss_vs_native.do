set more off
set varabbrev off

// Benchmark: pq use_spss vs native import spss
// Data generated by pq save_spss so no external file dependency.

capture program drop build_bench_data
program define build_bench_data
	version 16
	syntax, n_rows(integer)

	clear
	set obs `n_rows'

	gen long   id   = _n
	gen byte   grp  = mod(_n, 20)
	gen double x1   = rnormal()
	gen double x2   = runiform() * 1000
	gen double x3   = (rnormal() * 10) + grp
	gen double x4   = sqrt(_n)
	gen int    i1   = floor(runiform() * 32740)
	gen int    i2   = floor(runiform() * 5000) - 2500
	gen str8   s1   = char(65 + mod(_n, 26)) + string(mod(_n, 100))
	gen str20  s2   = "row_" + string(_n) + "_g" + string(grp)
end

local sizes     "100000 500000 1000000"
local reps      = 5
local subset_vars "id grp x1 s1"

tempfile spss_tmp
local spss_file "`spss_tmp'.sav"

di as text "Benchmark: pq use_spss vs import spss (pq-generated file)"
di as text "Reps per cell: `reps', Subset: `subset_vars'"
di as text ""
di as text "n_rows    | pq full(s) | native full(s) | pq speedup | pq sub(s) | native sub(s) | sub speedup"
di as text "----------|-----------|----------------|------------|-----------|---------------|------------"

set seed 20260304

foreach n of local sizes {
	build_bench_data, n_rows(`n')
	pq save_spss "`spss_file'", replace

	timer clear

	forvalues r = 1/`reps' {
		clear
		timer on 1
		pq use_spss using "`spss_file'", clear
		timer off 1
		assert _N == `n'

		clear
		timer on 2
		import spss using "`spss_file'", clear
		timer off 2
		assert _N == `n'

		clear
		timer on 3
		pq use `subset_vars' using "`spss_file'", clear format(spss)
		timer off 3
		assert _N == `n'

		clear
		timer on 4
		import spss `subset_vars' using "`spss_file'", clear
		timer off 4
		assert _N == `n'
	}

	timer list 1
	local t_pq_full     = r(t1) / `reps'
	timer list 2
	local t_nat_full    = r(t2) / `reps'
	timer list 3
	local t_pq_sub      = r(t3) / `reps'
	timer list 4
	local t_nat_sub     = r(t4) / `reps'

	local spd_full = `t_nat_full' / max(`t_pq_full', 1e-9)
	local spd_sub  = `t_nat_sub'  / max(`t_pq_sub',  1e-9)

	di as result ///
		%9.0gc `n' " | " ///
		%9.4f `t_pq_full'  " | " ///
		%14.4f `t_nat_full' " | " ///
		%10.2f `spd_full' "x | " ///
		%9.4f `t_pq_sub'   " | " ///
		%13.4f `t_nat_sub'  " | " ///
		%11.2f `spd_sub' "x"
}

capture erase "`spss_file'"

di as result _newline "Done."
